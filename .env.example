# ============================================
# SERVER CONFIGURATION
# ============================================
NODE_ENV=production
PORT=5000
HOST=0.0.0.0

# ============================================
# FIREBASE CONFIGURATION
# ============================================
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=your-client-email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYourPrivateKey\n-----END PRIVATE KEY-----\n"
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com

# ============================================
# REDIS CONFIGURATION
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# ============================================
# JWT CONFIGURATION
# ============================================
JWT_SECRET=your-super-secret-jwt-key-min-32-characters
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-characters
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# CORS CONFIGURATION
# ============================================
CORS_ORIGIN=http://localhost:3000,https://your-domain.com,https://web-production-xxxx.up.railway.app
SOCKET_CORS_ORIGIN=http://localhost:3000,https://your-domain.com,https://web-production-xxxx.up.railway.app
FRONTEND_URL=https://your-domain.com

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# ============================================
# UPLOAD CONFIGURATION
# ============================================
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# ============================================
# LOGGING CONFIGURATION
# ============================================
LOG_LEVEL=info
LOG_DIR=logs

# ============================================
# CACHE CONFIGURATION
# ============================================
CACHE_TTL=3600
CACHE_ENABLED=true

# ============================================
# EMAIL CONFIGURATION (untuk Invitation)
# ============================================
EMAIL_FROM=noreply@yourapp.com
EMAIL_SERVICE=console
# Untuk SendGrid (Production)
# SENDGRID_API_KEY=your-sendgrid-api-key
# Untuk Nodemailer (Alternative)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# ============================================
# INVITATION CONFIGURATION
# ============================================
INVITATION_EXPIRY_DAYS=7
MAX_INVITATIONS_PER_BATCH=50
INVITATION_REMINDER_DAYS=3,1

# ============================================
# SCREEN SHARING & RECORDING CONFIGURATION
# ============================================
SCREEN_CAPTURE_INTERVAL=1000
MAX_RECORDING_DURATION=1800
RECORDING_QUALITY=medium
MAX_SCREEN_SHARING_DURATION=3600
RECORDING_FRAME_RATE=15
RECORDING_BITRATE=1024

# ============================================
# SOCKET.IO CONFIGURATION
# ============================================
SOCKET_PING_TIMEOUT=60000
SOCKET_PING_INTERVAL=25000
SOCKET_MAX_HTTP_BUFFER_SIZE=1e6

# ============================================
# MONITORING CONFIGURATION
# ============================================
HEALTH_CHECK_INTERVAL=60000
METRICS_ENABLED=true
METRICS_PORT=9090

# ============================================
# SECURITY CONFIGURATION
# ============================================
BCRYPT_SALT_ROUNDS=10
PASSWORD_MIN_LENGTH=8
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=30

# ============================================
# AUDIT LOG CONFIGURATION
# ============================================
AUDIT_LOG_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=90

# ============================================
# NOTIFICATION CONFIGURATION
# ============================================
NOTIFICATION_BATCH_SIZE=100
NOTIFICATION_RETRY_ATTEMPTS=3
NOTIFICATION_RETRY_DELAY=5000

# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_MAX_CONNECTIONS=10
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=5000

# ============================================
# PERFORMANCE CONFIGURATION
# ============================================
COMPRESSION_LEVEL=6
JSON_LIMIT=50mb
URLENCODED_LIMIT=50mb
TRUST_PROXY=true

# ============================================
# RAILWAY SPECIFIC (Akan diisi otomatis oleh Railway)
# ============================================
# RAILWAY_STATIC_URL=
# RAILWAY_PUBLIC_DOMAIN=
# RAILWAY_PROJECT_ID=
# RAILWAY_SERVICE_NAME=

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_REGISTRATION=true
ENABLE_EMAIL_VERIFICATION=false
ENABLE_TWO_FACTOR_AUTH=false
ENABLE_DEVICE_MANAGEMENT=true
ENABLE_LICENSE_MANAGEMENT=true
ENABLE_PIN_ENROLLMENT=true
ENABLE_NOTIFICATIONS=true
ENABLE_AUDIT_LOG=true
ENABLE_REALTIME_UPDATES=true
ENABLE_SCREEN_SHARING=true
ENABLE_SCREEN_RECORDING=true
ENABLE_APP_MONITORING=true
ENABLE_MESSAGE_MONITORING=true
ENABLE_INVITATION=true

# ============================================
# DEBUGGING (Development Only)
# ============================================
DEBUG=false
SHOW_STACK_TRACE=false

# ============================================
# DEFAULT ADMIN USER (First Time Setup)
# ============================================
ADMIN_EMAIL=admin@yourapp.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@123456
ADMIN_FULL_NAME=Super Admin
