{
  "name": "admin-backend-firebase",
  "version": "1.0.0",
  "description": "Admin Backend with Firebase, Redis, Socket.IO - Complete Monitoring System",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "production": "NODE_ENV=production node src/app.js",
    "railway-start": "node src/app.js",
    "docker-start": "node src/app.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "format": "prettier --write src/**/*.js",
    "build": "npm install --production=false",
    "clean": "rm -rf node_modules package-lock.json",
    "postinstall": "echo '✅ Dependencies installed successfully'"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "compression": "^1.7.4",
    "express-rate-limit": "^6.7.0",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.0",
    "bcryptjs": "^2.4.3",
    "firebase-admin": "^11.8.0",
    "redis": "^4.6.5",
    "socket.io": "^4.6.1",
    "winston": "^3.9.0",
    "winston-daily-rotate-file": "^4.7.1",
    "morgan": "^1.10.0",
    "dotenv": "^16.0.3",
    "uuid": "^9.0.0",
    "multer": "^1.4.5-lts.1",
    "xss": "^1.0.14",
    "node-cron": "^3.0.2",
    "express-mongo-sanitize": "^2.2.0",
    "crypto": "^1.0.1",
    "axios": "^1.4.0",
    "nodemailer": "^6.9.3",
    "@sendgrid/mail": "^7.7.0",
    "compression": "^1.7.4",
    "helmet": "^7.0.0"
  },
  "devDependencies": {
    "nodemon": "^2.0.22",
    "jest": "^29.5.0",
    "supertest": "^6.3.3",
    "eslint": "^8.38.0",
    "prettier": "^2.8.7",
    "@types/jest": "^29.5.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-prettier": "^4.2.1"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "keywords": [
    "admin",
    "backend",
    "firebase",
    "redis",
    "socket.io",
    "monitoring",
    "screen-sharing",
    "screen-recording",
    "app-monitoring",
    "invitation"
  ],
  "author": "Admin Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/RohmanXmonitoring/backend.git"
  }
}
